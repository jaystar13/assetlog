generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  name       String
  avatar     String?
  provider   String   // "google" | "kakao"
  providerId String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  assets              Asset[]
  transactions        Transaction[]
  financialGoal       FinancialGoal?
  refreshTokens       RefreshToken[]
  createdGroups       ShareGroup[]         @relation("GroupCreator")
  groupMemberships    ShareGroupMember[]
  sharedItems         SharedItem[]         @relation("SharedItemOwner")
  groupInvitationsSent GroupInvitation[]   @relation("GroupInviter")

  @@unique([provider, providerId])
  @@map("users")
}

// ─── RefreshToken ────────────────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_tokens")
}

// ─── FinancialGoal ───────────────────────────────────────────────────────────

model FinancialGoal {
  id           String   @id @default(uuid())
  userId       String   @unique @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  startAmount  BigInt   @map("start_amount")
  targetAmount BigInt   @map("target_amount")
  deadline     DateTime
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("financial_goals")
}

// ─── Asset + ValueHistory ────────────────────────────────────────────────────

model Asset {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String    @map("category_id") // "real-estate" | "stocks" | "cash" | "loans"
  name       String
  status     String    @default("active") // "active" | "closed"
  closedAt   DateTime? @map("closed_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  valueHistory AssetValueHistory[]

  @@index([userId, categoryId])
  @@map("assets")
}

model AssetValueHistory {
  id        String   @id @default(uuid())
  assetId   String   @map("asset_id")
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  month     String   // "YYYY-MM"
  value     BigInt
  updatedAt DateTime @default(now()) @map("updated_at")

  @@unique([assetId, month])
  @@index([assetId])
  @@map("asset_value_history")
}

// ─── Transaction ─────────────────────────────────────────────────────────────

model Transaction {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String   // "income" | "expense"
  name              String
  amount            Int
  date              DateTime
  category          String
  subCategory       String   @map("sub_category")
  paymentMethod     String?  @map("payment_method")
  targetMonth       String?  @map("target_month")
  isInstallment     Boolean  @default(false) @map("is_installment")
  installmentMonths Int?     @map("installment_months")
  installmentRound  Int?     @map("installment_round")
  editedByUserId    String?  @map("edited_by_user_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([userId, date])
  @@index([userId, type])
  @@index([userId, targetMonth])
  @@map("transactions")
}

// ─── ShareGroup (공유 그룹) ──────────────────────────────────────────────────

model ShareGroup {
  id          String   @id @default(uuid())
  name        String
  createdById String   @map("created_by_id")
  createdBy   User     @relation("GroupCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members     ShareGroupMember[]
  sharedItems SharedItem[]
  invitations GroupInvitation[]

  @@index([createdById])
  @@map("share_groups")
}

model ShareGroupMember {
  id       String   @id @default(uuid())
  groupId  String   @map("group_id")
  group    ShareGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId   String   @map("user_id")
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     String   @default("viewer") // "admin" | "viewer"
  joinedAt DateTime @default(now()) @map("joined_at")

  @@unique([groupId, userId])
  @@index([userId])
  @@map("share_group_members")
}

// ─── SharedItem (개별 항목 공유) ─────────────────────────────────────────────

model SharedItem {
  id          String   @id @default(uuid())
  groupId     String   @map("group_id")
  group       ShareGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  ownerUserId String   @map("owner_user_id")
  owner       User     @relation("SharedItemOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  itemType    String   @map("item_type") // "transaction" | "asset"
  itemId      String   @map("item_id")
  sharedAt    DateTime @default(now()) @map("shared_at")

  @@unique([groupId, itemType, itemId])
  @@index([groupId, itemType])
  @@index([ownerUserId])
  @@index([itemId])
  @@map("shared_items")
}

// ─── GroupInvitation (그룹 초대) ─────────────────────────────────────────────

model GroupInvitation {
  id          String   @id @default(uuid())
  groupId     String   @map("group_id")
  group       ShareGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  invitedById String   @map("invited_by_id")
  invitedBy   User     @relation("GroupInviter", fields: [invitedById], references: [id], onDelete: Cascade)
  toEmail     String   @map("to_email")
  role        String   @default("viewer") // 수락 시 부여할 역할
  status      String   @default("pending") // "pending" | "accepted" | "declined" | "expired"
  message     String?
  sentAt      DateTime @default(now()) @map("sent_at")
  expiresAt   DateTime @map("expires_at")

  @@index([toEmail])
  @@index([groupId])
  @@map("group_invitations")
}

// ─── Seed Tables ─────────────────────────────────────────────────────────────

model CardCompany {
  id      String  @id @default(uuid())
  name    String
  format  String
  enabled Boolean @default(false)

  @@map("card_companies")
}

model DailyQuote {
  id     String @id @default(uuid())
  text   String
  author String

  @@map("daily_quotes")
}
